# ============================================================
# adforge — environment template
# Copy to .env and fill in. .env is gitignored.
# ============================================================

# ---- Google Gemini ----
# Video analysis in playable_forge; fallback labeller in creative_forge.
GEMINI_API_KEY=

# ---- Sensor Tower ----
# Ad intelligence — top advertisers, top creatives, store rankings.
# Used by creative_forge.
SENSORTOWER_API_KEY=

# ---- Anthropic Claude ----
# Leave blank if you only use Claude Code (subscription).
# Set if you script Claude calls directly via the SDK.
ANTHROPIC_API_KEY=

# ---- Mistral ----
# Default model for per-creative pattern labeling in creative_forge
# (cheap + fast for short JSON tasks). Falls back to Gemini if blank.
MISTRAL_API_KEY=

# ---- Scenario.com ----
# Provisioned at the event. Primary path is the Scenario MCP (OAuth — no key needed).
# Set the HTTP API keys only if you want fully headless rendering via Temporal.
SCENARIO_PROJECT_ID=
SCENARIO_API_KEY=
SCENARIO_SECRET_API_KEY=

# ---- Temporal (defaults match `temporal server start-dev`) ----
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adforge

# ---- Pipeline defaults ----
DEFAULT_COUNTRY=US
DEFAULT_CATEGORY_ID=7012   # iOS Puzzle. Strategy=7017, Casual=7003, RPG=7014, Sim=7015.
DEFAULT_NETWORK=TikTok
DEFAULT_PERIOD=month       # week | month | quarter
