{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m src.*)",
      "Bash(python -c *)",
      "Bash(pip install *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(open *)",
      "Bash(curl *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git checkout *)",
      "Bash(git branch*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force*)"
    ]
  }
}
